#!/usr/bin/env bash
# ============================================================
#  vision вҖ” HSM Monitor launcher
#  Usage: ./vision <command> [options]
# ============================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_DIR="$SCRIPT_DIR/java-app"
GRADLEW="$APP_DIR/gradlew"

# в”Җв”Җ мғүмғҒ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
YELLOW='\033[1;33m'; BOLD='\033[1m'; RESET='\033[0m'

info()  { echo -e "${CYAN}[vision]${RESET} $*"; }
ok()    { echo -e "${GREEN}[vision]${RESET} $*"; }
warn()  { echo -e "${YELLOW}[vision]${RESET} $*"; }
error() { echo -e "${RED}[vision] ERROR${RESET} $*" >&2; exit 1; }

# в”Җв”Җ лҸ„мӣҖл§җ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
usage() {
  echo -e "${BOLD}vision${RESET} вҖ” HSM Monitor launcher"
  echo ""
  echo -e "${BOLD}мӮ¬мҡ©лІ•:${RESET}"
  echo "  ./vision <command> [options]"
  echo ""
  echo -e "${BOLD}лӘ…л №:${RESET}"
  echo -e "  ${CYAN}start${RESET}                    GUI мӢӨн–ү"
  echo -e "  ${CYAN}test${RESET}                     лӢЁмң„ н…ҢмҠӨнҠё мӢӨн–ү"
  echo -e "  ${CYAN}build${RESET}                    л№Ңл“ң (н…ҢмҠӨнҠё нҸ¬н•Ё)"
  echo -e "  ${CYAN}algolist${RESET}                 HSM м§Җмӣҗ м•Ңкі лҰ¬мҰҳ лӘ©лЎқ м¶ңл Ҙ"
  echo -e "  ${CYAN}pqctest${RESET} -s <slot> -p <pin>  PQC HSM кІҖмҰқ (ML-DSA/ML-KEM)"
  echo -e "  ${CYAN}probeLuna${RESET}                LunaProvider л…ём¶ң м„ңл№„мҠӨ лҚӨн”„"
  echo -e "  ${CYAN}version${RESET}                  лІ„м „ м •ліҙ"
  echo -e "  ${CYAN}help${RESET}                     мқҙ лҸ„мӣҖл§җ"
  echo ""
  echo -e "${BOLD}мҳҲмӢң:${RESET}"
  echo "  ./vision start"
  echo "  ./vision test"
  echo "  ./vision algolist"
  echo "  ./vision pqctest -s 0 -p 12341234"
  echo "  ./vision start -PjavaVersion=21   # JDK 21лЎң нҸҙл°ұ"
  echo ""
  echo -e "${BOLD}Luna Client кІҪлЎң мҳӨлІ„лқјмқҙл“ң:${RESET}"
  echo "  ./vision start -PlunaClientPath=/opt/luna/client"
}

# в”Җв”Җ gradlew лһҳнҚј в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
gradlew() {
  cd "$APP_DIR" && bash gradlew "$@"
}

# в”Җв”Җ м»Өл§Ёл“ң нҢҢмӢұ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
CMD="${1:-help}"
shift || true

case "$CMD" in

  start)
    info "HSM Monitor GUI мӢңмһ‘..."
    gradlew run "$@"
    ;;

  test)
    info "лӢЁмң„ н…ҢмҠӨнҠё мӢӨн–ү..."
    gradlew test --console=plain "$@"
    ok "н…ҢмҠӨнҠё мҷ„лЈҢ"
    ;;

  build)
    info "л№Ңл“ң мӨ‘..."
    gradlew build "$@"
    ok "л№Ңл“ң мҷ„лЈҢ"
    ;;

  algolist)
    info "HSM м•Ңкі лҰ¬мҰҳ к°Җмҡ©м„ұ мЎ°нҡҢ..."
    gradlew algoList -q "$@"
    ;;

  pqctest)
    # -s <slot> -p <pin> нҢҢмӢұ
    SLOT="0"; PIN=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -s|--slot) SLOT="$2"; shift 2 ;;
        -p|--pin)  PIN="$2";  shift 2 ;;
        *) break ;;
      esac
    done
    [[ -z "$PIN" ]] && error "-p <PIN> мқҙ н•„мҡ”н•©лӢҲлӢӨ. мҳҲ: ./vision pqctest -s 0 -p YOUR_PIN"
    info "PQC HSM кІҖмҰқ (slot=$SLOT)..."
    gradlew pqcHsmTest -q "-Pslot=$SLOT" "-Ppin=$PIN" "$@"
    ;;

  probeluna|probeLuna)
    info "LunaProvider м„ңл№„мҠӨ лҚӨн”„..."
    gradlew probeLuna -q "$@"
    ;;

  version)
    VER=$(grep '^version' "$APP_DIR/build.gradle.kts" | head -1 | grep -oE '"[^"]+"' | tr -d '"')
    echo -e "${BOLD}vision${RESET} / HSM Monitor ${CYAN}$VER${RESET}"
    echo "  JDK  : $(java -version 2>&1 | head -1)"
    echo "  OS   : $(uname -sr)"
    ;;

  help|-h|--help)
    usage
    ;;

  *)
    warn "м•Ң мҲҳ м—ҶлҠ” лӘ…л №: $CMD"
    echo ""
    usage
    exit 1
    ;;
esac

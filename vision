#!/usr/bin/env bash
# ============================================================
#  vision — HSM Monitor launcher
#  Usage: ./vision <command> [options]
# ============================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_DIR="$SCRIPT_DIR/java-app"
GRADLEW="$APP_DIR/gradlew"

# ── 색상 ─────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
YELLOW='\033[1;33m'; BOLD='\033[1m'; RESET='\033[0m'

info()  { echo -e "${CYAN}[vision]${RESET} $*"; }
ok()    { echo -e "${GREEN}[vision]${RESET} $*"; }
warn()  { echo -e "${YELLOW}[vision]${RESET} $*"; }
error() { echo -e "${RED}[vision] ERROR${RESET} $*" >&2; exit 1; }

# ── 도움말 ────────────────────────────────────────────────────
usage() {
  echo -e "${BOLD}vision${RESET} — HSM Monitor launcher"
  echo ""
  echo -e "${BOLD}사용법:${RESET}"
  echo "  ./vision <command> [options]"
  echo ""
  echo -e "${BOLD}명령:${RESET}"
  echo -e "  ${CYAN}start${RESET}                    GUI 실행"
  echo -e "  ${CYAN}test${RESET}                     단위 테스트 실행"
  echo -e "  ${CYAN}build${RESET}                    빌드 (테스트 포함)"
  echo -e "  ${CYAN}algolist${RESET}                 HSM 지원 알고리즘 목록 출력"
  echo -e "  ${CYAN}pqctest${RESET} -s <slot> -p <pin>  PQC HSM 검증 (ML-DSA/ML-KEM)"
  echo -e "  ${CYAN}probeLuna${RESET}                LunaProvider 노출 서비스 덤프"
  echo -e "  ${CYAN}version${RESET}                  버전 정보"
  echo -e "  ${CYAN}help${RESET}                     이 도움말"
  echo ""
  echo -e "${BOLD}예시:${RESET}"
  echo "  ./vision start"
  echo "  ./vision test"
  echo "  ./vision algolist"
  echo "  ./vision pqctest -s 0 -p 12341234"
  echo "  ./vision start -PjavaVersion=21   # JDK 21로 폴백"
  echo ""
  echo -e "${BOLD}Luna Client 경로 오버라이드:${RESET}"
  echo "  ./vision start -PlunaClientPath=/opt/luna/client"
}

# ── gradlew 래퍼 ─────────────────────────────────────────────
gradlew() {
  cd "$APP_DIR" && bash gradlew "$@"
}

# ── 커맨드 파싱 ───────────────────────────────────────────────
CMD="${1:-help}"
shift || true

case "$CMD" in

  start)
    info "HSM Monitor GUI 시작..."
    gradlew run "$@"
    ;;

  test)
    info "단위 테스트 실행..."
    gradlew test --console=plain "$@"
    ok "테스트 완료"
    ;;

  build)
    info "빌드 중..."
    gradlew build "$@"
    ok "빌드 완료"
    ;;

  algolist)
    info "HSM 알고리즘 가용성 조회..."
    gradlew algoList -q "$@"
    ;;

  pqctest)
    # -s <slot> -p <pin> 파싱
    SLOT="0"; PIN=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -s|--slot) SLOT="$2"; shift 2 ;;
        -p|--pin)  PIN="$2";  shift 2 ;;
        *) break ;;
      esac
    done
    [[ -z "$PIN" ]] && error "-p <PIN> 이 필요합니다. 예: ./vision pqctest -s 0 -p YOUR_PIN"
    info "PQC HSM 검증 (slot=$SLOT)..."
    gradlew pqcHsmTest -q "-Pslot=$SLOT" "-Ppin=$PIN" "$@"
    ;;

  probeluna|probeLuna)
    info "LunaProvider 서비스 덤프..."
    gradlew probeLuna -q "$@"
    ;;

  version)
    VER=$(grep '^version' "$APP_DIR/build.gradle.kts" | head -1 | grep -oE '"[^"]+"' | tr -d '"')
    echo -e "${BOLD}vision${RESET} / HSM Monitor ${CYAN}$VER${RESET}"
    echo "  JDK  : $(java -version 2>&1 | head -1)"
    echo "  OS   : $(uname -sr)"
    echo ""
    echo -e "  ${CYAN}JDK 버전 지정:${RESET} ./vision start -PjavaVersion=21"
    echo -e "  ${CYAN}PQC(JDK 내장):${RESET} JDK 25 필요 (HSM PQC는 21에서도 동작)"
    ;;

  help|-h|--help)
    usage
    ;;

  *)
    warn "알 수 없는 명령: $CMD"
    echo ""
    usage
    exit 1
    ;;
esac

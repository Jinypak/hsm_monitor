<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="LOG_PATTERN">%d{HH:mm:ss.SSS} %-5level [%t] %logger{36} - %msg%n</Property>
        <Property name="LOG_DIR">${sys:user.home}/.hsm-monitor/logs</Property>
    </Properties>

    <Appenders>
        <!-- consoleLevel 시스템 속성으로 콘솔 출력을 제어.
             CLI 하니스(cmd cp949)에서는 -DconsoleLevel=OFF 로 한글 로그 깨짐을 방지하고
             하니스의 영문 System.out 만 남긴다. 기본값 DEBUG(기존 동작 유지). -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <ThresholdFilter level="${sys:consoleLevel:-DEBUG}" onMatch="ACCEPT" onMismatch="DENY"/>
        </Console>

        <RollingFile name="File"
                     fileName="${LOG_DIR}/app.log"
                     filePattern="${LOG_DIR}/app-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Logger name="com.yours.hsm" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Logger>

        <Logger name="javafx" level="WARN"/>

        <Root level="INFO">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>

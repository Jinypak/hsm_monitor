<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.yours.hsm.ui.SignVerifyController"
      spacing="0" styleClass="tab-content">

    <!-- 설정 영역 -->
    <VBox styleClass="panel" spacing="8">
        <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
        <Label text="서명·검증 설정" styleClass="section-title"/>

        <GridPane hgap="10" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="80" prefWidth="100"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="메커니즘" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <ComboBox fx:id="mechCombo" maxWidth="Infinity" styleClass="dark-combo"
                      GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="키" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <ComboBox fx:id="keyCombo" maxWidth="Infinity" styleClass="dark-combo"
                      GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        </GridPane>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="속도 (ops/sec):" styleClass="form-label"/>
            <Slider fx:id="rateSlider" min="0.1" max="10.0" value="1.0"
                    showTickLabels="true" showTickMarks="true"
                    majorTickUnit="1" minorTickCount="4"
                    HBox.hgrow="ALWAYS"/>
            <Label fx:id="rateLabel" text="1.0" styleClass="muted-label" minWidth="30"/>
        </HBox>

        <HBox spacing="6" alignment="CENTER_LEFT">
            <CheckBox fx:id="extVerifyCheck" text="외부 검증 (SunRsaSign)" styleClass="dark-check" selected="true"/>
        </HBox>

        <HBox spacing="8">
            <Button fx:id="startBtn"    text="▶ 시작"   styleClass="btn-primary"  onAction="#onStart"/>
            <Button fx:id="stopBtn"     text="■ 중지"   styleClass="btn-danger"  onAction="#onStop"     disable="true"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="saveJsonBtn" text="JSON 저장" styleClass="btn-secondary" onAction="#onSaveJson" disable="true"/>
            <Button fx:id="saveCsvBtn"  text="CSV 저장"  styleClass="btn-secondary" onAction="#onSaveCsv"  disable="true"/>
        </HBox>
    </VBox>

    <!-- 통계 -->
    <HBox styleClass="stats-bar" spacing="20">
        <padding><Insets top="8" right="14" bottom="8" left="14"/></padding>
        <VBox spacing="2" alignment="CENTER">
            <Label text="전체"    styleClass="stat-label"/>
            <Label fx:id="totalLabel" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox spacing="2" alignment="CENTER">
            <Label text="성공"    styleClass="stat-label"/>
            <Label fx:id="passLabel"  text="0" styleClass="stat-value,stat-pass"/>
        </VBox>
        <VBox spacing="2" alignment="CENTER">
            <Label text="실패"    styleClass="stat-label"/>
            <Label fx:id="failLabel"  text="0" styleClass="stat-value,stat-fail"/>
        </VBox>
        <VBox spacing="2" alignment="CENTER">
            <Label text="ops/sec"  styleClass="stat-label"/>
            <Label fx:id="rateValueLabel" text="0.0" styleClass="stat-value"/>
        </VBox>
        <VBox spacing="2" alignment="CENTER">
            <Label text="평균 서명" styleClass="stat-label"/>
            <Label fx:id="avgSignLabel"   text="—" styleClass="stat-value"/>
        </VBox>
        <VBox spacing="2" alignment="CENTER">
            <Label text="평균 검증" styleClass="stat-label"/>
            <Label fx:id="avgVerifyLabel" text="—" styleClass="stat-value"/>
        </VBox>
        <VBox spacing="2" alignment="CENTER">
            <Label text="경과"      styleClass="stat-label"/>
            <Label fx:id="elapsedLabel"   text="0s" styleClass="stat-value"/>
        </VBox>
    </HBox>

    <!-- 로그 -->
    <VBox VBox.vgrow="ALWAYS" spacing="4">
        <padding><Insets top="8" right="14" bottom="8" left="14"/></padding>
        <Label text="로그" styleClass="section-title"/>
        <TextArea fx:id="logArea" VBox.vgrow="ALWAYS" editable="false"
                  styleClass="log-area" wrapText="false"/>
        <HBox spacing="8">
            <Button text="로그 지우기" styleClass="btn-secondary" onAction="#onClearLog"/>
        </HBox>
    </VBox>

</VBox>
